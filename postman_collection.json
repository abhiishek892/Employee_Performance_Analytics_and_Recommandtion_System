{
  "info": {
    "name": "Employee Performance AI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "employeeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/auth/signup",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Add Employee",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/employees",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aman Verma\",\n  \"email\": \"aman@gmail.com\",\n  \"department\": \"Development\",\n  \"skills\": [\"React\", \"Node.js\", \"MongoDB\"],\n  \"performanceScore\": 85,\n  \"experience\": 3\n}"
        }
      }
    },
    {
      "name": "Get All Employees",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/employees"
      }
    },
    {
      "name": "Search Employee By Department",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/employees/search?department=Development"
      }
    },
    {
      "name": "Update Employee",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/employees/{{employeeId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"performanceScore\": 92\n}"
        }
      }
    },
    {
      "name": "AI Recommendation",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/ai/recommend",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employees\": [\n    {\n      \"name\": \"Aman Verma\",\n      \"email\": \"aman@gmail.com\",\n      \"department\": \"Development\",\n      \"skills\": [\"React\", \"Node.js\", \"MongoDB\"],\n      \"performanceScore\": 85,\n      \"experience\": 3\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Delete Employee",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      }
    }
  ]
}
